# ============================================================
# AgenticAI-2-Incident-Response — Environment Variables
# INSTRUÇÃO: Copie para .env e preencha os valores.
# Em produção/staging: busque os valores do vault (ver paths abaixo).
# NUNCA commite o .env com valores reais — bloqueado por gitleaks.
# ============================================================

# --- Ambiente (development | staging | production) ---
APP_ENV=development

# --- Anthropic ---
# Vault path (prod): secret/agentic-ai/prod/anthropic/api_key
# Vault path (staging): secret/agentic-ai/staging/anthropic/api_key
ANTHROPIC_API_KEY=sk-ant-...

# --- API Key do Incident-Response-Agent ---
# Vazio em development desabilita autenticação (bypass apenas localmente).
# Obrigatório em staging e production (A01/A05).
# Vault path: secret/agentic-ai/{env}/ira/api_key  [rotation: 90d]
API_KEY=

# --- Admin Key (endpoints /admin/*) ---
# Vault path: secret/agentic-ai/{env}/ira/admin_key  [rotation: 90d]
ADMIN_KEY=

# --- Prometheus metrics endpoint (Log-Ingestion) ---
# Vazio em development = sem autenticação. Obrigatório em staging/production (A05).
# Vault path: secret/agentic-ai/{env}/prometheus/api_key
PROMETHEUS_API_KEY=

# --- Redis ---
# Vault path: secret/agentic-ai/{env}/redis/url
REDIS_URL=redis://redis:6379
# Vault path: secret/agentic-ai/{env}/redis/password  [rotation: 24h]
REDIS_PASSWORD=

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
# Vault path: secret/agentic-ai/{env}/qdrant/api_key
QDRANT_API_KEY=

# --- Knowledge-Base service URL (usado pelo Agent) ---
KB_API_URL=http://knowledge-base:8002
# Mesma chave da API_KEY acima; separado para facilitar rotation independente
# Vault path: secret/agentic-ai/{env}/kb/api_key
KB_API_KEY=${API_KEY}

# --- Log-Ingestion-and-Metrics service URL (usado pelo Agent) ---
METRICS_API_URL=http://log-ingestion:8000

# --- OpenTelemetry ---
OTLP_ENDPOINT=http://jaeger:4317

# --- CORS — origens permitidas (nunca * em produção) ---
# Múltiplas origens separadas por vírgula
# Ex. produção: https://sre-dashboard.example.com,https://grafana.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Thresholds para fallback de análise por regras ---
LATENCY_P99_THRESHOLD_MS=1000
ERROR_RATE_5XX_THRESHOLD_PCT=1.0

# --- Docs (desabilitar em production) ---
ENABLE_DOCS=true
